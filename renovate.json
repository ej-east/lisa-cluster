{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "argocd": {
    "fileMatch": ["argocd-applications/.+\\.ya?ml$", "bootstrap/.+\\.ya?ml$"]
  },
  "kubernetes": {
    "fileMatch": ["manifests/.+\\.ya?ml$"]
  },
  "helm-values": {
    "fileMatch": ["manifests/.+/values\\.ya?ml$"]
  }
}
